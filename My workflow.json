        "toolDescription": "Use this tool to update the customer's billing amount from the 'billing' table using a specific customer ID.\n\nThis tool should only be used when the payment has been confirmed.\n\nOnce the payment has been confirmed, the paid amount should be subtracted from 'amount_due'.",
        "operation": "update",
        "tableId": "billing",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "customer_id",
              "condition": "eq",
              "keyValue": "=  {{ $fromAI('customer_id', 'the customer\\'s id as provided in the chat. Do not guess values. If you do not know what to input, ask for it respectfully.') }}"
            },
            {
              "keyName": "bill_id",
              "condition": "eq",
              "keyValue": "={{ $fromAI('bill_id', 'the customer\\'s bill id as discussed in the chat. Do not guess values. If you\\'re not sure what to input, ask for it respectfully.') }}"
