      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Use this tool to retrieve customer billing information, including billing cycle, amount due, due date, payment status, and outstanding balance, from the 'billing' table using a specific customer ID.",
        "operation": "getAll",
        "tableId": "billing",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "customer_id",
              "condition": "eq",
              "keyValue": "={{ $fromAI('customer_id', 'the customer\\'s ID as provided in the chat. Do not guess values. If you do not know what to input, ask for it respectfully.') }}"
